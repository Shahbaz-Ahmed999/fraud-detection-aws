# Fraud Detection AWS - .gitignore
# Generated for Python ML project with AWS integration

# ==========================================
# PYTHON
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
fraud-env/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ==========================================
# DATA FILES (NEVER COMMIT LARGE DATA!)
# ==========================================

# Raw data (download separately)
data/raw/*.csv
data/raw/*.zip
data/raw/*.json
data/raw/*.parquet

# Processed data
data/processed/*.csv
data/processed/*.pkl
data/processed/*.h5
data/processed/*.parquet

# Interim data
data/interim/*.csv
data/interim/*.pkl

# Database files
*.db
*.sqlite
*.sqlite3

# Excel files (if large)
*.xlsx
*.xls

# ==========================================
# MODELS & ARTIFACTS
# ==========================================

# Saved models (these can be large!)
models/saved_models/*.pkl
models/saved_models/*.joblib
models/saved_models/*.h5
models/saved_models/*.pb
models/saved_models/*.pt
models/saved_models/*.pth
models/saved_models/*.onnx

# Model checkpoints
models/checkpoints/*.ckpt
models/checkpoints/*.hdf5

# TensorFlow
*.h5
*.pb

# PyTorch
*.pth
*.pt

# Scikit-learn
*.pkl
*.joblib

# ONNX
*.onnx

# ==========================================
# AWS CREDENTIALS (CRITICAL - NEVER COMMIT!)
# ==========================================

# AWS credentials
.aws/credentials
.aws/config
**/credentials
**/config

# Environment variables
.env
.env.local
.env.*.local

# AWS SAM
.aws-sam/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# ==========================================
# LOGS & OUTPUTS
# ==========================================

# Log files
*.log
logs/
*.out

# Output files
outputs/
results/
experiments/

# ==========================================
# IDE & EDITOR
# ==========================================

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ==========================================
# OPERATING SYSTEM
# ==========================================

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ==========================================
# PROJECT-SPECIFIC
# ==========================================

# Experiment tracking
mlruns/
experiments/

# Notebooks with outputs (optional - remove if you want to commit outputs)
notebooks/**/*-checkpoint.ipynb

# Temporary files
tmp/
temp/
*.tmp

# API keys (in case stored in files)
**/api_keys.txt
**/secrets.txt
**/token.txt

# Large test files
test_data_large/

# ==========================================
# DOCUMENTATION BUILD
# ==========================================

# Sphinx documentation
docs/_build/
docs/_static/
docs/_templates/

# ==========================================
# KEEP THESE FOLDERS (even if empty)
# ==========================================

!data/.gitkeep
!models/.gitkeep
!logs/.gitkeep

# ==========================================
# EXCEPTIONS (files to KEEP)
# ==========================================

# Keep small sample data for testing
!data/raw/sample_*.csv
!data/raw/README.md

# Keep model architecture files (not weights)
!models/architecture/*.json
!models/architecture/*.yaml

# Keep requirements
!requirements.txt
!environment.yml

# Keep configuration templates
!config/*.template
!config/*.example
lambda_layer/ 
xgboost_layer/ 
lambda_deployment.zip 
lambda_layer.zip 
response.json 
